{
    "workbench.statusBar.visible": true,
    "workbench.editor.showTabs": "multiple",
    "workbench.activityBar.location": "default",
    "workbench.colorTheme": "Visual Studio Light",
    "terminal.integrated.fontLigatures.enabled": true,
    "workbench.colorCustomizations": {
        "[Visual Studio Light]": {
            "terminal.background": "#0C0C0C",
            "terminal.foreground": "#CCCCCC",
            "terminal.inactiveSelectionBackground": "#3A3D41",
            "terminal.ansiBlue": "#3B78FF",
            "terminal.ansiBrightBlue": "#0037DA",
            "terminal.ansiBrightCyan": "#3A96DD",
            "terminal.ansiBrightGreen": "#4EED91",
            "terminal.ansiBrightMagenta": "#D670FF",
            "terminal.ansiBrightRed": "#FF6C60",
            "terminal.ansiBrightWhite": "#F2F2F2",
            "terminal.ansiBrightYellow": "#F4BF75",
            "terminal.ansiCyan": "#29B8DB",
            "terminal.ansiGreen": "#00B300",
            "terminal.ansiMagenta": "#A74CBE",
            "terminal.ansiRed": "#FF0000",
            "terminal.ansiWhite": "#BEBEBE",
            "terminal.ansiYellow": "#F0F000",
            "terminal.ansiBrightBlack": "#000000",
            "terminal.ansiBlack": "#767676",
            "terminalCursor.foreground": "#FFFFFF",
        }
    },
    "demoTime.highlightBlur": 1,
    "demoTime.showClock": false,
    "demoTime.insertTypingMode": "character-by-character",
    "demoTime.nextActionBehaviour": "currentPosition",
    "demoTime.highlightBackground": "rgba(0,0,0,0)",
    "demoTime.defaultFileType": "yaml",
    "editor.fontFamily": "'CaskaydiaCove Nerd Font', 'Cascadia Code', Consolas, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.inlineSuggest.enabled": false,
    "editor.autoClosingBrackets": "never",
    "editor.cursorWidth": 3,
    "editor.hover.enabled": "off",
    "editor.autoClosingComments": "never",
    "editor.autoIndent": "none",
    "editor.autoIndentOnPasteWithinString": false,
    "js/ts.preferences.jsxAttributeCompletionStyle": "none",
    "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
    "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": false,
    "js/ts.suggest.enabled": false,
    "terminal.integrated.suggest.enabled": false,
    "terminal.integrated.suggest.inlineSuggestion": "off",
    "terminal.integrated.shellIntegration.quickFixEnabled": false,
    "terminal.integrated.stickyScroll.enabled": false,
    "terminal.integrated.shellIntegration.showCommandGuide": false,
    "terminal.integrated.shellIntegration.decorationsEnabled": "never",
    "terminal.integrated.commandsToSkipShell": [
        "demo-time.start"
    ]
}